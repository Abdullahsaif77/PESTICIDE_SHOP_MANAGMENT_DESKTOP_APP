{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "description": "Pesticide Shop Management System",
  "author": "Your Company Name",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "preview": "vite preview",
    "lint": "eslint .",
    "postinstall": "electron-builder install-app-deps",
    "test:build": "npm run build && npm run electron"
  },
  "dependencies": {
    "adm-zip": "0.5.17",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.11.1",
    "concurrently": "10.0.3",
    "countup.js": "2.10.1",
    "cross-env": "10.1.0",
    "date-fns": "4.4.0",
    "framer-motion": "12.42.2",
    "jspdf": "4.2.1",
    "jspdf-autotable": "5.0.8",
    "lucide-react": "1.21.0",
    "react": "^19.2.6",
    "react-countup": "6.5.3",
    "react-dom": "^19.2.6",
    "react-hot-toast": "2.6.0",
    "react-router-dom": "7.18.0",
    "recharts": "3.9.2",
    "wait-on": "9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "10.5.0",
    "electron-builder": "26.15.3",
    "electron": "42.4.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.myapp.desktop",
    "productName": "My Desktop App",
    "directories": {
      "output": "dist-electron",
      "buildResources": "src/assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo.png"
    },
    "mac": {
      "icon": "src/assets/logo.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "icon": "src/assets/logo.png",
      "category": "Office",
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "My Desktop App",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "uninstallDisplayName": "My Desktop App",
      "deleteAppDataOnUninstall": false
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "compression": "maximum"
  }
}